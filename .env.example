# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Public app URL used by Convex Auth OAuth redirects.
SITE_URL=http://localhost:3000

# Convex deployment URL used by the frontend and auth integration.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_SITE_URL=

# GitHub OAuth app used as the only sign-in method.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel OAuth app used for the post-login account connection step.
AUTH_VERCEL_ID=
AUTH_VERCEL_SECRET=

# Backwards-compatible names if you already configured the old manual flow.
NEXT_PUBLIC_VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
