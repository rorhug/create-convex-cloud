    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
